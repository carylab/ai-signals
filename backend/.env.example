# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=AI Signals
APP_ENV=development          # development | production | test
DEBUG=false
SECRET_KEY=change-me-to-a-random-32-char-string
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default for local dev)
DATABASE_URL=sqlite+aiosqlite:///./data/db/ai_signals.db

# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_signals

# ── LLM ───────────────────────────────────────────────────────────────────────
# Choose one provider:  openai | anthropic | deepseek | openrouter
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

LLM_MAX_RETRIES=3
LLM_TIMEOUT_S=60
LLM_TEMPERATURE=0.3

# ── Pipeline ──────────────────────────────────────────────────────────────────
PIPELINE_CRON=0 6 * * *       # daily at 06:00 UTC
PIPELINE_ENABLED=true
PIPELINE_MAX_ARTICLES_PER_RUN=500
PIPELINE_MIN_PUBLISH_SCORE=0.25

# ── Crawler ───────────────────────────────────────────────────────────────────
CRAWLER_REQUEST_TIMEOUT_S=30
CRAWLER_MAX_CONCURRENT=10

# ── Export ────────────────────────────────────────────────────────────────────
EXPORT_DIR=./data/exports

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=console            # console | json
