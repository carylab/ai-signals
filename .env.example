# AI Signals — root environment template
# Copy to .env and fill in values before running locally.
# Never commit this file with real secrets.

# ── LLM (required) ────────────────────────────────────────────────────────────
LLM_PROVIDER=openai                   # openai | anthropic | deepseek | openrouter
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

# ── Frontend (required for Vercel deploy) ─────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=https://aisignals.io
NEXT_PUBLIC_SITE_NAME=AI Signals

# ── Vercel deploy secrets (CI) ────────────────────────────────────────────────
# VERCEL_TOKEN=...
# VERCEL_ORG_ID=...
# VERCEL_PROJECT_ID=...

# ── Fly.io deploy secrets (CI) ────────────────────────────────────────────────
# FLY_API_TOKEN=...
